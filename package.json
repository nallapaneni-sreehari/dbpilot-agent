{
  "name": "dbpilot-agent",
  "version": "1.0.2",
  "description": "Local tunnel agent for DBPilot — forwards queries from the DBPilot server to your localhost database",
  "main": "dist/index.js",
  "bin": {
    "dbpilot-agent": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "dbpilot",
    "database",
    "tunnel",
    "agent",
    "localhost"
  ],
  "author": "Sreehari Nallapaneni",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nallapaneni-sreehari/dbpilot-agent.git"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts"
  },
  "dependencies": {
    "mongodb": "^6.6.1",
    "mysql2": "^3.9.7",
    "pg": "^8.11.5",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/pg": "^8.11.5",
    "@types/ws": "^8.5.10",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18"
  }
}
